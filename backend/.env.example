# ===== Backend =====
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=eu-jap-hack

# Walt.id Services
WALTID_ISSUER_URL=http://localhost:7002
WALTID_VERIFIER_URL=http://localhost:7003

# ===== Gaia-X Configuration =====
# Set to false to use live Gaia-X endpoints instead of mock
GAIAX_MOCK_MODE=true

# Timeout for Gaia-X API calls (ms)
GAIAX_TIMEOUT=15000

# Number of retry attempts per request
GAIAX_RETRY_ATTEMPTS=2

# Delay between retries (ms)
GAIAX_RETRY_DELAY=1000

# Max number of companies allowed to onboard (leave unset for unlimited)
MAX_COMPANIES=10

# ===== EDC (Eclipse Dataspace Connector) =====
ENABLE_EDC=true
EDC_BASE_URL=https://your-edc-instance.com
EDC_API_KEY=your-api-key
BPN_NUMBER=BPNL00000TATAMOTOR
APP_BASE_URL=http://localhost:8000
EDC_ACCESS_POLICY_ID=policy_2
EDC_CONTRACT_POLICY_ID=policy_2

# EDC Consumer (Insurance/Nissan side)
EDC_CONSUMER_MANAGEMENT_URL=https://your-consumer-controlplane.example.com/management
EDC_CONSUMER_API_KEY=your-consumer-api-key
# EDC_PARTNER_BPN and EDC_PARTNER_DSP_URL removed — now discovered from issuer DID DataService endpoint

# EDC Negotiation polling
EDC_NEGOTIATION_INITIAL_DELAY_MS=5000
EDC_NEGOTIATION_POLL_INTERVAL_MS=5000
EDC_NEGOTIATION_MAX_RETRIES=3

# CADDE (Cross-domain data exchange)
CADDE_ASSET_ID=your-cadde-asset-id
CADDE_PARTNER_EDC_DSP_URL=https://partner-protocol.example.com/api/v1/dsp
CADDE_PARTNER_EDC_BPN=BPNL00000000XXXX
