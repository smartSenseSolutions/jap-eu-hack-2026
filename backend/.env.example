# =============================================================================
# Authentication
# =============================================================================

# Set to true to enforce JWT authentication via Keycloak
AUTH_ENABLED=false

# Keycloak base URL
KEYCLOAK_URL=http://localhost:8080

# Keycloak realm name
KEYCLOAK_REALM=eu-jap-hack

# Keycloak admin client ID (used for creating users during company onboarding)
KEYCLOAK_ADMIN_CLIENT_ID=realm_admin_client

# Keycloak admin client secret (required for admin operations)
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# =============================================================================
# Walt.id Services
# =============================================================================

# Walt.id Wallet API URL
WALTID_WALLET_URL=http://localhost:7001

# Walt.id Issuer API URL
WALTID_ISSUER_URL=http://localhost:7002

# Walt.id Verifier API URL
WALTID_VERIFIER_URL=http://localhost:7003

# =============================================================================
# Gaia-X Configuration
# =============================================================================

# Set to true to use mock Gaia-X endpoints (no real compliance check)
GAIAX_MOCK_MODE=true

# Timeout for Gaia-X API calls (ms)
GAIAX_TIMEOUT=15000

# Number of retry attempts per Gaia-X request
GAIAX_RETRY_ATTEMPTS=2

# Delay between retries (ms)
GAIAX_RETRY_DELAY=1000

# Public domain for DID resolution (e.g. your ngrok or production domain, no https://)
GAIAX_DID_DOMAIN=jeh-api.tx.the-sense.io

# DID document path component (e.g. v1, v7)
GAIAX_DID_PATH=v1

# Override Gaia-X Lab endpoints (optional - defaults to public Gaia-X Lab URLs)
# GAIAX_LAB_COMPLIANCE_URL=https://compliance.lab.gaia-x.eu/development
# GAIAX_LAB_REGISTRY_URL=https://registry.lab.gaia-x.eu/v2
# GAIAX_LAB_NOTARY_URL=https://notary.lab.gaia-x.eu/v2

# =============================================================================
# Application
# =============================================================================

# Public base URL of this backend (used for DID documents and EDC callbacks)
APP_BASE_URL=http://localhost:8000

# =============================================================================
# EDC Provisioning
# =============================================================================

# Set to true to auto-provision an EDC instance on company onboarding
ENABLE_EDC_PROVISIONING=false

# URL of the EDC provisioning microservice
PROVISIONING_SERVICE_URL=http://localhost:3010

# Maximum number of companies allowed to onboard (leave unset for unlimited)
MAX_COMPANIES=10

# =============================================================================
# EDC (Eclipse Dataspace Connector) — Provider side
# =============================================================================

# Enable EDC integration for asset/car registration
ENABLE_EDC=true

# Provider EDC management API URL
EDC_BASE_URL=https://your-edc-instance.com

# Provider EDC API key
EDC_API_KEY=your-api-key

# Business Partner Number of this node
BPN_NUMBER=BPNL00000TATAMOTOR

# Access policy ID used when registering assets in EDC
EDC_ACCESS_POLICY_ID=policy_2

# Contract policy ID used when registering assets in EDC
EDC_CONTRACT_POLICY_ID=policy_2

# =============================================================================
# EDC — Consumer side (Insurance / Tokio Marine)
# =============================================================================

# Consumer EDC management API URL
EDC_CONSUMER_MANAGEMENT_URL=https://your-consumer-controlplane.example.com/management

# Consumer EDC API key
EDC_CONSUMER_API_KEY=your-consumer-api-key

# Initial delay before polling negotiation status (ms)
EDC_NEGOTIATION_INITIAL_DELAY_MS=5000

# Interval between negotiation status polls (ms)
EDC_NEGOTIATION_POLL_INTERVAL_MS=5000

# Max number of negotiation polling retries
EDC_NEGOTIATION_MAX_RETRIES=3

# =============================================================================
# EDC — Seed data URLs (per-tenant FQDNs for the seeded edc_provisioning rows)
# These are the actual ingress hostnames of the EDC deployments. Seed.ts reads
# them verbatim — no string interpolation, no domain inference. Set them to
# whatever the deployed EDC ingresses are (may be a separate cluster from APP).
# =============================================================================

# Toyota tenant (provider)
TOYOTA_EDC_PROTOCOL_URL=https://your-toyota-protocol.example.com/api/v1/dsp
TOYOTA_EDC_MANAGEMENT_URL=https://your-toyota-controlplane.example.com/management
TOYOTA_EDC_DATAPLANE_URL=https://your-toyota-dataplane.example.com

# Tokio Marine tenant (consumer)
TOKIOMARINE_EDC_PROTOCOL_URL=https://your-tokiomarine-protocol.example.com/api/v1/dsp
TOKIOMARINE_EDC_MANAGEMENT_URL=https://your-tokiomarine-controlplane.example.com/management
TOKIOMARINE_EDC_DATAPLANE_URL=https://your-tokiomarine-dataplane.example.com

# =============================================================================
# CADDE (Cross-domain data exchange)
# =============================================================================

# Asset ID of the CADDE data offer
CADDE_ASSET_ID=your-cadde-asset-id

# Partner EDC DSP endpoint URL
CADDE_PARTNER_EDC_DSP_URL=https://partner-protocol.example.com/api/v1/dsp

# Partner Business Partner Number
CADDE_PARTNER_EDC_BPN=BPNL00000000XXXX
